{
  "name": "claude-todos",
  "displayName": "Claude Todos",
  "description": "%extension.description%",
  "version": "0.10.0",
  "license": "MIT",
  "publisher": "CarlosJunior1992",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlosdealmeida/claude-todos-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/carlosdealmeida/claude-todos-vscode/issues"
  },
  "homepage": "https://github.com/carlosdealmeida/claude-todos-vscode#readme",
  "galleryBanner": {
    "color": "#1F1B16",
    "theme": "dark"
  },
  "keywords": [
    "claude",
    "claude-code",
    "todo",
    "tasks",
    "task tracking",
    "agent",
    "subagent",
    "ai",
    "anthropic"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeTodos",
          "title": "Claude Todos",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeTodos": [
        {
          "type": "webview",
          "id": "claudeTodos.view",
          "name": "%view.todos.name%",
          "contextualTitle": "Claude Todos"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeTodos.openPanel",
        "title": "%command.openPanel.title%"
      },
      {
        "command": "claudeTodos.installHook",
        "title": "%command.installHook.title%"
      },
      {
        "command": "claudeTodos.refresh",
        "title": "%command.refresh.title%"
      }
    ],
    "keybindings": [
      {
        "command": "claudeTodos.openPanel",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t"
      }
    ],
    "configuration": {
      "title": "Claude Todos",
      "properties": {
        "claudeTodos.claudeDir": {
          "type": "string",
          "default": "",
          "description": "%config.claudeDir.description%"
        },
        "claudeTodos.autoInstallHook": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoInstallHook.description%"
        },
        "claudeTodos.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "pt-br",
            "es"
          ],
          "enumDescriptions": [
            "%config.language.auto%",
            "%config.language.en%",
            "%config.language.ptBr%",
            "%config.language.es%"
          ],
          "default": "auto",
          "description": "%config.language.description%"
        },
        "claudeTodos.notifications": {
          "type": "boolean",
          "default": true,
          "description": "%config.notifications.description%"
        }
      }
    }
  },
  "scripts": {
    "build:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:hook": "esbuild src/hooks/sessionStart.ts --bundle --outfile=dist/hooks/sessionStart.js --format=cjs --platform=node",
    "build:webview": "vite build",
    "build": "npm run build:ext && npm run build:hook && npm run build:webview",
    "watch": "npm run build -- --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@types/node": "^20.19.41",
    "@types/vscode": "~1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.1",
    "svelte": "^5.55.9",
    "svelte-check": "^3.8.6",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
